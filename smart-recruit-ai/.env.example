# Example environment variables for SmartRecruit-AI
# Copy to .env and fill values before running

# App
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/smartrecruit

# Redis (used by cache + BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# JWT secret
JWT_SECRET=your_jwt_secret_here

# CORS - comma separated list or '*' to allow all origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.example.com
# Or to allow all origins for testing (not recommended for production):
# ALLOWED_ORIGINS=*
# Optional regex to allow origins e.g. ^https:\/\/.*\.github\.dev$
ALLOWED_ORIGINS_REGEX=

# Frontend URL used in OAuth redirects
FRONTEND_URL=http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI / Gemini API key
GEMINI_API_KEY=

# Optional: enable credentials support in CORS (true/false)
ALLOW_CREDENTIALS=true

# Additional settings
LOG_LEVEL=info
